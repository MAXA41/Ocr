# Web3Forms primary email delivery
VITE_ORDER_PROVIDER=web3forms
VITE_WEB3FORMS_ACCESS_KEY=

# Backup delivery channel.
# You can point this to a Make, n8n or Pipedream webhook that forwards orders to Telegram and/or email.
# For stable local ops, point this at your permanent public n8n hostname.
VITE_ORDER_FALLBACK_WEBHOOK_URL=

# true  = send to webhook even when Web3Forms succeeds
# false = use webhook only when Web3Forms fails
VITE_ORDER_DUPLICATE_TO_WEBHOOK=true

# Shared secret for validating requests in n8n.
# Note: in a static frontend this is only a basic gate, not strong security.
VITE_ORDER_WEBHOOK_SHARED_SECRET=

# Nova Poshta API key for cities, branches, and lockers lookup.
VITE_NOVA_POSHTA_API_KEY=

# Supabase frontend config
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_AUTH_REDIRECT_URL=

# Server-side and local n8n secrets.
# Prefer setting these as user-level environment variables instead of storing them in .env.local.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
PUBLIC_SITE_URL=
MONO_MERCHANT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
ORDER_WEBHOOK_SHARED_SECRET=
ORDER_ADMIN_SHARED_SECRET=
ORDER_COMPLETION_WEBHOOK_URL=http://127.0.0.1:5678/webhook/ocr-orders-complete
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_TELEGRAM_BOT_TOKEN=
N8N_TELEGRAM_ADMIN_CHAT_ID=
N8N_TELEGRAM_ADMIN_WEBHOOK_PATH=ocr-telegram-admin
N8N_ORDER_WEBHOOK_PATH=ocr-orders-supabase
N8N_ORDER_COMPLETE_WEBHOOK_PATH=ocr-orders-complete
CLOUDFLARED_TUNNEL_TOKEN=
N8N_PUBLIC_BASE_URL=
ORDER_ADMIN_SHARED_SECRET=
