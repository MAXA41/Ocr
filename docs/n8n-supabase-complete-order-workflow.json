      "parameters": {
        "httpMethod": "POST",
        "path": "ocr-orders-complete",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "1",
      "name": "Complete Order Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        340
      ],
      "webhookId": "ocr-orders-complete"
    },
    {
      "parameters": {
        "jsCode": "const incoming = $json.body && typeof $json.body === 'object' ? $json.body : $json;\nconst payload = incoming.data && typeof incoming.data === 'object' ? incoming.data : incoming;\nconst expectedAdminSecret = $env.ORDER_ADMIN_SHARED_SECRET || '';\nconst rawOrderId = String(payload.orderId || payload.id || '').trim();\nconst rawOrderNumber = String(payload.orderNumber || '').trim();\nconst safeOrderId = /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(rawOrderId)\n  ? rawOrderId\n  : '00000000-0000-0000-0000-000000000000';\nconst parsedOrderNumber = Number(rawOrderNumber);\nconst safeOrderNumber = Number.isInteger(parsedOrderNumber) && parsedOrderNumber > 0 ? parsedOrderNumber : -1;\nconst hasReference = Boolean(rawOrderId) || safeOrderNumber > 0;\nconst sharedSecretValid = Boolean(expectedAdminSecret) && payload.adminSecret === expectedAdminSecret;\nconst isValid = hasReference && sharedSecretValid;\nconst validationMessage = !sharedSecretValid\n  ? 'Invalid admin secret'\n  : (!hasReference ? 'Order reference is required' : 'ok');\n\nreturn [{\n  json: {\n    payload,\n    valid: isValid,\n    validationMessage,\n    safeOrderId,\n    safeOrderNumber\n  }\n}];"
      },
      "id": "2",
      "name": "Validate Completion Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        340
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.valid}}",
              "value2": true
            }
          ]
        }
      },
      "id": "3",
      "name": "Request Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        760,
        340
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/orders?id=eq.' + $json.safeOrderId + '&select=id,order_number,status,total_amount,customer_name,customer_email,completed_at'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SECRET_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SECRET_KEY}}"
            }
          ]
        },
        "options": {}
      },
      "id": "4",
      "name": "Find Order By Id",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
