        "respondWith": "json",
        "responseBody": "={\n  \"ok\": true,\n  \"message\": \"Order marked as completed\",\n  \"orderId\": $('Resolve Target Order').item.json.orderId,\n  \"orderNumber\": $('Resolve Target Order').item.json.orderNumber\n}",
        "options": {}
      },
