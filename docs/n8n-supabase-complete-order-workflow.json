      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/orders?order_number=eq.' + $json.safeOrderNumber + '&select=id,order_number,status,total_amount,customer_name,customer_email,completed_at'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SECRET_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SECRET_KEY}}"
            }
          ]
        },
        "options": {}
      },
      "id": "5",
      "name": "Find Order By Number",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1280,
        240
      ]
    },
    {
      "parameters": {
        "jsCode": "const byId = $('Find Order By Id').first()?.json || [];\nconst byNumber = $('Find Order By Number').first()?.json || [];\nconst found = (Array.isArray(byId) && byId.length > 0 ? byId[0] : null) || (Array.isArray(byNumber) && byNumber.length > 0 ? byNumber[0] : null);\n\nif (!found) {\n  return [{\n    json: {\n      orderFound: false,\n      alreadyCompleted: false,\n      invalidStatus: false,\n      shouldComplete: false,\n      responseMessage: 'Order not found'\n    }\n  }];\n}\n\nconst status = String(found.status || 'new');\nconst alreadyCompleted = status === 'completed';\nconst invalidStatus = ['canceled', 'refunded'].includes(status);\nconst shouldComplete = !alreadyCompleted && !invalidStatus;\nconst customerLabel = found.customer_name || found.customer_email || '-';\nconst totalAmount = Number(found.total_amount || 0);\n\nreturn [{\n  json: {\n    orderFound: true,\n    alreadyCompleted,\n    invalidStatus,\n    shouldComplete,\n    orderId: found.id,\n    orderNumber: found.order_number,\n    status,\n    totalAmount,\n    customerLabel,\n    responseMessage: alreadyCompleted\n      ? 'Order is already completed'\n      : (invalidStatus ? `Order cannot be completed from status ${status}` : 'ok'),\n    telegramText: [\n      'Замовлення переведено в completed',\n      '',\n      `Номер замовлення: #${found.order_number || '-'}`,\n      `Клієнт: ${customerLabel}`,\n      `Сума до накопичення: ${totalAmount} грн`,\n      `Новий статус: completed`\n    ].join('\\n')\n  }\n}];"
      },
