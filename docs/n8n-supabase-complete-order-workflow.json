        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ status: 'completed', completed_at: new Date().toISOString(), accumulation_amount: Number($json.totalAmount || 0) }) }}",
        "options": {}
      },
