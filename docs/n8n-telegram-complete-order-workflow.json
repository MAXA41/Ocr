      },
      "id": "4",
      "name": "Has Complete Command?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1020,
        260
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.ORDER_COMPLETION_WEBHOOK_URL}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ orderId: $json.orderId, orderNumber: $json.orderNumber, adminSecret: $env.ORDER_ADMIN_SHARED_SECRET }) }}",
        "options": {}
      },
      "id": "5",
      "name": "Call Completion Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1280,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const request = $('Parse Telegram Command').item.json;\nconst response = $json;\nconst ok = Boolean(response.ok);\nconst message = String(response.message || (ok ? 'Готово' : 'Не вдалося виконати команду'));\nconst orderNumber = response.orderNumber || request.orderNumber || '-';\nconst finalText = ok\n  ? [`Готово.`, '', `Замовлення: #${orderNumber}`, `Результат: ${message}`].join('\\n')\n  : [`Помилка.`, '', `Замовлення: #${orderNumber}`, `Причина: ${message}`].join('\\n');\n\nreturn [{\n  json: {\n    chatId: request.chatId,\n    finalText\n  }\n}];"
      },
      "id": "6",
      "name": "Format Completion Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        220
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.isListCommand}}",
              "value2": true
            }
          ]
        }
      },
      "id": "10",
      "name": "Has List Command?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1280,
        460
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/orders?status=in.(new,paid,processing,shipped)&select=id,order_number,status,total_amount,customer_name,city,delivery_method_label,placed_at&order=placed_at.desc&limit=10'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SECRET_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SECRET_KEY}}"
            }
          ]
        },
        "options": {}
      },
      "id": "11",
      "name": "Load Open Orders",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        420
      ]
    },
    {
      "parameters": {
        "jsCode": "const request = $('Parse Telegram Command').item.json;\nconst rows = Array.isArray($json) ? $json : [];\nconst openOrders = rows.filter(Boolean);\n\nconst finalText = openOrders.length === 0\n  ? 'Зараз немає відкритих замовлень.'\n  : [\n      'Відкриті замовлення:',\n      '',\n      ...openOrders.map((order) => {\n        const number = order.order_number || '-';\n        const customer = order.customer_name || '-';\n        const status = order.status || '-';\n        const city = order.city || '-';\n        const delivery = order.delivery_method_label || '-';\n        const total = Number(order.total_amount || 0);\n        return `#${number} | ${customer} | ${total} грн | ${status} | ${city} | ${delivery}`;\n      }),\n      '',\n      'Щоб завершити:',\n      '/complete 123'\n    ].join('\\n');\n\nreturn [{\n  json: {\n    chatId: request.chatId,\n    finalText\n  }\n}];"
      },
      "id": "12",
      "name": "Format Orders Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1800,
        420
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/sendMessage'}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, text: $json.finalText }) }}",
        "options": {}
      },
