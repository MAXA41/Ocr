{
  "name": "OCR Orders: Telegram Admin Commands",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ocr-telegram-admin",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "1",
      "name": "Telegram Admin Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        340
      ],
      "webhookId": "ocr-telegram-admin"
    },
    {
      "parameters": {
        "jsCode": "const update = $json.body && typeof $json.body === 'object' ? $json.body : $json;\nconst message = update.message || update.edited_message || null;\nconst chatId = message?.chat?.id ? String(message.chat.id) : '';\nconst text = String(message?.text || '').trim();\nconst allowedChatIds = String($env.TELEGRAM_ADMIN_CHAT_ID || '')\n  .split(',')\n  .map((value) => value.trim())\n  .filter(Boolean);\nconst chatAllowed = allowedChatIds.length > 0 && allowedChatIds.includes(chatId);\nconst normalizedText = text.replace(/\s+/g, ' ').trim();\nconst isHelp = normalizedText === '/start' || normalizedText === '/help';\nconst completeMatch = normalizedText.match(/^\/complete\s+(.+)$/i);\nconst rawReference = completeMatch ? completeMatch[1].trim() : '';\nconst isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(rawReference);\nconst numericOrder = Number(rawReference);\nconst orderNumber = Number.isInteger(numericOrder) && numericOrder > 0 ? numericOrder : null;\nconst orderId = isUuid ? rawReference : null;\nconst isCompleteCommand = Boolean(completeMatch) && Boolean(orderId || orderNumber);\nconst isListCommand = /^\/(orders|new|neworders)$/i.test(normalizedText);\nconst helpText = [\n  'Команди менеджера OCR:',\n  '',\n  '/orders',\n  '/new',\n  '/neworders',\n  '/complete 123',\n  '/complete uuid-замовлення',\n  '',\n  'Приклади:',\n  '/orders',\n  '/complete 154'\n].join('\\n');\n\nlet replyText = helpText;\nif (!chatAllowed) {\n  replyText = 'Цей чат не має доступу до admin-команд.';\n} else if (isCompleteCommand) {\n  replyText = orderNumber\n    ? `Пробую завершити замовлення #${orderNumber}...`\n    : `Пробую завершити замовлення ${orderId}...`;\n} else if (isListCommand) {\n  replyText = 'Завантажую список відкритих замовлень...';\n} else if (!isHelp) {\n  replyText = 'Невідома команда. Використай /help';\n}\n\nreturn [{\n  json: {\n    update,\n    chatId,\n    text: normalizedText,\n    chatAllowed,\n    isHelp,\n    isCompleteCommand,\n    isListCommand,\n    orderId,\n    orderNumber,\n    replyText,\n    helpText\n  }\n}];"
      },
      "id": "2",
      "name": "Parse Telegram Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        340
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.chatAllowed}}",
              "value2": true
            }
          ]
        }
      },
      "id": "3",
      "name": "Chat Allowed?",
      "type": "n8n-nodes-base.if",
